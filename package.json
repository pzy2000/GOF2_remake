{
  "name": "gof2-by-pzy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "tsc -b && vite build",
    "server:dev": "npm run server:build && npm run server:start",
    "server:build": "tsc -p tsconfig.server.json && vite build --config vite.server.config.ts",
    "server:start": "node dist-server/economy-server.mjs",
    "server:multiplayer:start": "node dist-server/multiplayer-server.mjs",
    "test": "vitest run --environment node --globals",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --grep \"mobile and foldable layouts|PWA preview\"",
    "test:e2e:mobile:screenshots": "GOF2_UPDATE_MOBILE_MATRIX=1 playwright test --grep \"mobile and foldable layouts\"",
    "test:watch": "vitest",
    "generate:voices": "node scripts/generate-voice-lines.mjs",
    "generate:premium-assets": "node scripts/generate-premium-assets.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "msedge-tts": "^2.0.5",
    "patch-package": "^8.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
